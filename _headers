# Cache static assets for repeat visits (Lighthouse: efficient cache lifetimes)
# GitHub Pages may not apply these; Netlify/Cloudflare Pages will.
# See: https://developer.mozilla.org/en-US/docs/Web/HTTP/Headers/Cache-Control

/*.css
  Cache-Control: public, max-age=31536000, immutable

/*.png
  Cache-Control: public, max-age=31536000, immutable

/*.jpg
  Cache-Control: public, max-age=31536000, immutable

/*.jpeg
  Cache-Control: public, max-age=31536000, immutable

/*.webp
  Cache-Control: public, max-age=31536000, immutable

/*.woff2
  Cache-Control: public, max-age=31536000, immutable

/*.svg
  Cache-Control: public, max-age=31536000, immutable
